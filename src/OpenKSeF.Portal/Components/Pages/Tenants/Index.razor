@page "/tenants"
@attribute [Authorize]
@inject ITenantCrudService TenantCrudService
@inject IJSRuntime JS

<PageTitle>Tenants</PageTitle>

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Dashboard</a></li>
        <li class="breadcrumb-item active" aria-current="page">Tenants</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Tenants</h1>
    <a class="btn btn-primary" href="/tenants/create">Create tenant</a>
</div>

@if (_isLoading)
{
    <div class="d-flex align-items-center gap-2">
        <div class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></div>
        <span>Loading tenants...</span>
    </div>
}
else if (_errorMessage is not null)
{
    <div class="alert alert-danger" role="alert">@_errorMessage</div>
}
else if (_tenants.Count == 0)
{
    <div class="alert alert-info" role="alert">No tenants configured yet.</div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>NIP</th>
                <th>Name</th>
                <th>Notification Email</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var tenant in _tenants)
            {
                <tr>
                    <td>@tenant.Nip</td>
                    <td>@(string.IsNullOrWhiteSpace(tenant.DisplayName) ? "-" : tenant.DisplayName)</td>
                    <td>@(string.IsNullOrWhiteSpace(tenant.NotificationEmail) ? "-" : tenant.NotificationEmail)</td>
                    <td class="text-end">
                        <a class="btn btn-outline-secondary btn-sm me-2" href="/tenants/edit/@tenant.Id">Edit</a>
                        <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteAsync(tenant.Id, tenant.Nip)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private bool _isLoading = true;
    private string? _errorMessage;
    private IReadOnlyList<OpenKSeF.Domain.Entities.Tenant> _tenants = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task DeleteAsync(Guid id, string nip)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Delete tenant {nip}?");
        if (!confirmed)
        {
            return;
        }

        var result = await TenantCrudService.DeleteAsync(id);
        if (!result.Success)
        {
            _errorMessage = result.ErrorMessage;
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            _tenants = await TenantCrudService.ListAsync();
        }
        catch
        {
            _errorMessage = "Unable to load tenants.";
        }
        finally
        {
            _isLoading = false;
        }
    }
}
