@page "/tenants/edit/{Id:guid}"
@attribute [Authorize]
@inject ITenantCrudService TenantCrudService
@inject NavigationManager Navigation

<PageTitle>Edit Tenant</PageTitle>

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Dashboard</a></li>
        <li class="breadcrumb-item"><a href="/tenants">Tenants</a></li>
        <li class="breadcrumb-item active" aria-current="page">Edit</li>
    </ol>
</nav>

<h1 class="h3">Edit tenant</h1>

@if (_isLoading)
{
    <div class="d-flex align-items-center gap-2">
        <div class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></div>
        <span>Loading tenant...</span>
    </div>
}
else if (_model is null)
{
    <div class="alert alert-danger" role="alert">Tenant not found or access denied.</div>
}
else
{
    if (_errorMessage is not null)
    {
        <div class="alert alert-danger" role="alert">@_errorMessage</div>
    }

    <EditForm Model="_model" OnValidSubmit="HandleSubmitAsync" class="mt-3">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label class="form-label" for="nip">NIP</label>
            <InputText id="nip" class="form-control" @bind-Value="_model.Nip" />
        </div>

        <div class="mb-3">
            <label class="form-label" for="displayName">Name</label>
            <InputText id="displayName" class="form-control" @bind-Value="_model.DisplayName" />
        </div>

        <div class="mb-3">
            <label class="form-label" for="notificationEmail">Notification Email</label>
            <InputText id="notificationEmail" class="form-control" @bind-Value="_model.NotificationEmail" />
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Save</button>
            <a class="btn btn-outline-secondary" href="/tenants">Cancel</a>
        </div>
    </EditForm>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private bool _isLoading = true;
    private TenantFormModel? _model;
    private string? _errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        _model = await TenantCrudService.GetAsync(Id);
        _isLoading = false;
    }

    private async Task HandleSubmitAsync()
    {
        if (_model is null)
        {
            return;
        }

        _errorMessage = null;
        var result = await TenantCrudService.UpdateAsync(Id, _model);
        if (!result.Success)
        {
            _errorMessage = result.ErrorMessage;
            return;
        }

        Navigation.NavigateTo("/tenants");
    }
}
