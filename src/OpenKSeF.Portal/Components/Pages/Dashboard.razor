@page "/"
@attribute [Authorize]
@inherits TenantScopedComponentBase
@inject IDashboardService DashboardService

<PageTitle>Dashboard</PageTitle>

<h1>Dashboard</h1>

@if (_isLoading)
{
    <div class="d-flex align-items-center gap-2">
        <div class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></div>
        <span>Loading tenant overview...</span>
    </div>
}
else if (_errorMessage is not null)
{
    <div class="alert alert-danger" role="alert">@_errorMessage</div>
}
else if (_summaries.Count == 0)
{
    <div class="alert alert-info" role="alert">
        No tenants configured yet.
        <a href="/tenants" class="ms-1">Add your first tenant</a>.
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var summary in _summaries)
        {
            <div class="col-12 col-lg-6">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h2 class="h5 mb-1">@summary.DisplayName ?? $"Tenant {summary.Nip}"</h2>
                                <p class="text-muted mb-2">NIP: @summary.Nip</p>
                            </div>
                            <span class="@GetStatusBadgeClass(summary.SyncStatus)">@summary.SyncStatus</span>
                        </div>

                        <div class="small text-muted mb-3">
                            Last successful sync:
                            @if (summary.LastSuccessfulSync.HasValue)
                            {
                                <strong>@summary.LastSuccessfulSync.Value.ToString("u")</strong>
                            }
                            else
                            {
                                <strong>Never</strong>
                            }
                        </div>

                        <div class="row text-center mb-3">
                            <div class="col">
                                <div class="fw-bold">@summary.TotalInvoices</div>
                                <div class="small text-muted">Total</div>
                            </div>
                            <div class="col">
                                <div class="fw-bold">@summary.InvoicesLast7Days</div>
                                <div class="small text-muted">Last 7 days</div>
                            </div>
                            <div class="col">
                                <div class="fw-bold">@summary.InvoicesLast30Days</div>
                                <div class="small text-muted">Last 30 days</div>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <a class="btn btn-outline-primary btn-sm" href="/tenants">Tenants</a>
                            <a class="btn btn-outline-secondary btn-sm" href="/credentials">Credentials</a>
                            <a class="btn btn-outline-dark btn-sm" href="/invoices">Invoices</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private bool _isLoading = true;
    private string? _errorMessage;
    private IReadOnlyList<TenantDashboardSummary> _summaries = [];

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        try
        {
            _summaries = await DashboardService.GetTenantOverviewAsync();
        }
        catch
        {
            _errorMessage = "Unable to load dashboard data.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static string GetStatusBadgeClass(SyncHealthStatus status) => status switch
    {
        SyncHealthStatus.Success => "badge text-bg-success",
        SyncHealthStatus.Warning => "badge text-bg-warning",
        _ => "badge text-bg-danger"
    };
}
