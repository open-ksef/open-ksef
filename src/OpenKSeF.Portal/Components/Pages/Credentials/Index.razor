@page "/credentials"
@attribute [Authorize]
@inject ICredentialStatusService CredentialStatusService

<PageTitle>Credential Status</PageTitle>

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Dashboard</a></li>
        <li class="breadcrumb-item active" aria-current="page">Credentials</li>
    </ol>
</nav>

<h1 class="h3 mb-3">KSeF Credential Status</h1>

@if (_isLoading)
{
    <div class="d-flex align-items-center gap-2">
        <div class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></div>
        <span>Loading credential statuses...</span>
    </div>
}
else if (_errorMessage is not null)
{
    <div class="alert alert-danger" role="alert">@_errorMessage</div>
}
else if (_rows.Count == 0)
{
    <div class="alert alert-info" role="alert">No tenant credentials found.</div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>NIP</th>
                <th>Tenant Name</th>
                <th>Credential Type</th>
                <th>Token Configured</th>
                <th>Last Successful Sync</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in _rows)
            {
                <tr>
                    <td>@row.Nip</td>
                    <td>@(string.IsNullOrWhiteSpace(row.DisplayName) ? "-" : row.DisplayName)</td>
                    <td>Token</td>
                    <td>@(row.TokenConfigured ? "Yes" : "No")</td>
                    <td>@(row.LastSuccessfulSync?.ToString("u") ?? "Never")</td>
                    <td>
                        <span class="@GetStatusBadgeClass(row.Status)">@row.Status</span>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private bool _isLoading = true;
    private string? _errorMessage;
    private IReadOnlyList<TenantCredentialStatusRow> _rows = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _rows = await CredentialStatusService.GetStatusesAsync();
        }
        catch
        {
            _errorMessage = "Unable to load credential status.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static string GetStatusBadgeClass(CredentialHealthStatus status) => status switch
    {
        CredentialHealthStatus.Active => "badge text-bg-success",
        CredentialHealthStatus.Warning => "badge text-bg-warning",
        _ => "badge text-bg-danger"
    };
}
