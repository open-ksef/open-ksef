@page "/devices"
@attribute [Authorize]
@inject ITenantCrudService TenantCrudService
@inject IDeviceTokenOverviewService DeviceTokenOverviewService

<PageTitle>Devices</PageTitle>

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Dashboard</a></li>
        <li class="breadcrumb-item active" aria-current="page">Devices</li>
    </ol>
</nav>

<h1 class="h3 mb-3">Registered Mobile Devices</h1>

<div class="card mb-3">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-12 col-md-4">
                <label class="form-label" for="tenantId">Tenant</label>
                <select id="tenantId" class="form-select" @bind="_selectedTenantRaw">
                    <option value="">All tenants</option>
                    @foreach (var tenant in _tenants)
                    {
                        <option value="@tenant.Id">@(tenant.DisplayName ?? tenant.Nip) (@tenant.Nip)</option>
                    }
                </select>
            </div>

            <div class="col-12 col-md-3">
                <button class="btn btn-primary" @onclick="ApplyFilters">Apply</button>
            </div>
        </div>
    </div>
</div>

@if (_isLoading)
{
    <div class="d-flex align-items-center gap-2">
        <div class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></div>
        <span>Loading devices...</span>
    </div>
}
else if (_errorMessage is not null)
{
    <div class="alert alert-danger" role="alert">@_errorMessage</div>
}
else if (_rows.Count == 0)
{
    <div class="alert alert-info" role="alert">No registered mobile devices found.</div>
}
else
{
    <div class="text-muted small mb-2">Registered devices: @_rows.Count</div>
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Platform</th>
                <th>Token</th>
                <th>Registered At</th>
                <th>Last Seen</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in _rows)
            {
                <tr>
                    <td>@row.Platform</td>
                    <td><code>@row.TokenMasked</code></td>
                    <td>@row.RegisteredAt.ToString("u")</td>
                    <td>@row.LastSeenAt.ToString("u")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private bool _isLoading = true;
    private string? _errorMessage;
    private IReadOnlyList<OpenKSeF.Domain.Entities.Tenant> _tenants = [];
    private IReadOnlyList<OpenKSeF.Portal.Services.DeviceTokenOverviewRow> _rows = [];
    private string _selectedTenantRaw = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _tenants = await TenantCrudService.ListAsync();
            _rows = await DeviceTokenOverviewService.ListAsync();
        }
        catch
        {
            _errorMessage = "Unable to load device tokens.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ApplyFilters()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            _rows = await DeviceTokenOverviewService.ListAsync(ParseTenantId());
        }
        catch
        {
            _errorMessage = "Unable to load device tokens.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private Guid? ParseTenantId() =>
        Guid.TryParse(_selectedTenantRaw, out var tenantId) ? tenantId : null;
}
