# Postgres (used by both Keycloak and open-ksef app)
POSTGRES_USER=openksef
POSTGRES_PASSWORD=change_me

# Keycloak admin (first login)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change_me

# Optional (if you want different DB creds for Keycloak than POSTGRES_*)
# KC_DB_USERNAME=openksef
# KC_DB_PASSWORD=change_me

# AES-256-GCM encryption key for KSeF tokens at rest (required in production)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=generate_with_openssl_rand

# CIRFMF NuGet feed credentials (GitHub Packages)
# Required for Docker build to pull KSeF.Client package.
# Create a GitHub PAT (classic) with read:packages scope.
# See README.md "NuGet feed setup" for details.
# NUGET_CIRFMF_USER=YOUR_GITHUB_USERNAME
# NUGET_CIRFMF_PAT=YOUR_GITHUB_PAT_WITH_READ_PACKAGES

# Keycloak openksef-api client secret
# Auto-configured by dev-env-up.ps1 at runtime. Do NOT set manually for dev.
# API_CLIENT_SECRET=

# Google OAuth (for Keycloak Google IdP -- leave empty to disable Google sign-in)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# KSeF environment
# KSEF_BASE_URL=https://ksef-test.mf.gov.pl/api

# Docker Compose host port override for the public gateway (optional; default shown)
# The full app is available under one host port:
# - portal: /
# - api: /api/*
# - keycloak: /auth/*
# APP_HOST_PORT=8080
# API_HOST_PORT=8081
# KEYCLOAK_HOST_PORT=8082
# PORTAL_WEB_HOST_PORT=8083
# POSTGRES_HOST_PORT=5432
# Public URL used by SPA redirects, API token issuer validation, and
# Keycloak realm redirect URIs. Set to your ngrok/tunnel HTTPS URL when
# the MAUI app needs HTTPS (e.g. APP_EXTERNAL_BASE_URL=https://my-tunnel.ngrok-free.app).
# Defaults to http://localhost:8080 when unset.
APP_EXTERNAL_BASE_URL=http://localhost:8080

# Firebase Cloud Messaging (for Android push notifications)
# Paste your Firebase service account JSON here (single line, no newlines)
# Obtain from: Firebase Console > Project Settings > Service Accounts > Generate new private key
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# APNs (for iOS push notifications)
# APNS_BUNDLE_ID=com.openksef.mobile
# APNS_BASE_URL=https://api.push.apple.com

# KSeF auth mode and optional certificate settings
# KSeF__AuthMode=Auto
# KSeF__Certificate__Path=/secure/path/openksef-certificate.pfx
# KSeF__Certificate__Password=read_from_secret_store
# KSeF__Certificate__StoreLocation=CurrentUser
# KSeF__Certificate__StoreName=My
# KSeF__Certificate__Thumbprint=
